{
    "version": 2,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.1",
            "maxDuration": 30,
            "memory": 1024
        }
    },
    "routes": [
        { "src": "/build/(.*)", "dest": "/public/build/$1" },
        { "src": "/js/filament/(.*)", "dest": "/public/js/filament/$1" },
        { "src": "/css/filament/(.*)", "dest": "/public/css/filament/$1" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],

    "env": {
       "APP_ENV": "production",
        "APP_DEBUG": "true",
        "ASSET_URL": "https://honey-company.vercel.app",
        "VIEW_COMPILED_PATH": "/tmp",
        "SESSION_DRIVER": "cookie",
        "LOG_CHANNEL": "stderr"
    }
}